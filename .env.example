NODE_ENV=development
APP_NAME="NEXUS OPERACIONAL"
WEB_PORT=3000
API_PORT=3333
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=nexus_operacional
POSTGRES_PORT=5432
WEB_ORIGIN=http://localhost:3000
API_URL=http://localhost:3333
NEXT_PUBLIC_API_URL=http://localhost:3333/api

DATABASE_URL="postgresql://nexus:change-this-postgres-password@localhost:5432/nexus_operacional?schema=public"
JWT_ACCESS_SECRET="replace-with-a-long-random-access-secret"
JWT_REFRESH_SECRET="replace-with-a-long-random-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
AUTH_COOKIE_SAMESITE="lax"

INITIAL_ADMIN_EMAIL=admin@nexus.local
INITIAL_ADMIN_PASSWORD="replace-with-a-temporary-strong-password"
COMPANY_NAME="Empresa"
LEGACY_EXCEL_PATH=
BACKUP_DIR="./backups"
LOG_LEVEL=info
